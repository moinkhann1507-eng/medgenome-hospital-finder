// This is your Prisma schema file,
// Supports both SQLite (dev) and PostgreSQL (Supabase/Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id          Int      @id
  name        String
  address     String   @default("")
  city        String   @default("")
  state       String   @default("")
  district    String   @default("")
  pincode     String   @default("")
  lat         Float?
  lng         Float?
  category    String   @default("general")
  careType    String   @default("")
  discipline  String   @default("")
  ownership   String   @default("Unknown")
  beds        String   @default("0")
  emergency   Boolean  @default(false)
  phones      String   @default("[]")
  specialties String   @default("")
  facilities  String   @default("")
}
